# Environment Configuration
NODE_ENV=production

# ========================================
# Website Configuration
# ========================================
# The internal container port and the external mapped port
WEBSITE_PORT=5500
# The domain used by Traefik/Coolify to route traffic to the website
WEBSITE_DOMAIN=ibnbatoutaweb.com

# ========================================
# Admin Configuration
# ========================================
# The internal container port and the external mapped port
ADMIN_PORT=5600
# The domain used by Traefik/Coolify to route traffic to the admin panel
ADMIN_DOMAIN=admin.ibnbatoutaweb.com
# Admin credentials used by server-side authentication
ADMIN_USER=admin
ADMIN_PASS=change_this_password
# Optional: force secure session cookies (set true behind HTTPS reverse proxy)
COOKIE_SECURE=
